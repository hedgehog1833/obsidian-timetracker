{
  "compilerOptions": {
		"allowSyntheticDefaultImports": true,
    "inlineSourceMap": true,
    "inlineSources": true,
		"jsx": "react-jsx",
    "module": "nodenext",
    "target": "ES6",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "nodenext",
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
		"rootDir": ".",
    "types": ["node", "jest"],
    "lib": ["DOM", "ES5", "ES6", "ES7", "ESNext"]
  },
  "include": [
    "**/*.ts"
  ]
}
