		"luxon": "^3.7.2",
		"moment-duration-format": "^2.3.2",
		"obsidian": "^1.13.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"tslib": "2.8.1"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@eslint-react/eslint-plugin": "^5.9.0",
